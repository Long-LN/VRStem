  m_Name: Intro
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequenceSO
  segments:
  - subTitle: "Ch\xE0o m\u1EEBng nh\xE0 th\xE1m hi\u1EC3m nh\xED \u0111\xE3 \u0111\u1EBFn
      v\u1EDBi tr\u1EA1m quan s\xE1t v\u0169 tr\u1EE5! Tr\u01B0\u1EDBc m\u1EB7t b\u1EA1n
      l\xE0 H\u1EC7 M\u1EB7t Tr\u1EDDi c\u1EE7a ch\xFAng ta, nh\u01B0ng c\xE1c h\xE0nh
      tinh \u0111ang b\u1ECB \u1EA9n t\xEAn b\u1EDFi nh\u1EEFng d\u1EA5u h\u1ECFi
      ch\u1EA5m. Nhi\u1EC7m v\u1EE5 c\u1EE7a b\u1EA1n l\xE0 gi\u1EA3i m\xE3 danh
      t\xEDnh c\u1EE7a t\u1EEBng h\xE0nh tinh \u0111\u1EC3 ho\xE0n th\xE0nh b\u1EA3n
      \u0111\u1ED3 thi\xEAn v\u0103n n\xE0y."
    voiceClip: {fileID: 8300000, guid: 6e07ba66085d12842a0c16ff4a2c7d46, type: 3}
    delayAfter: 2
  - subTitle: "\u0110\u1EC3 b\u1EAFt \u0111\u1EA7u, h\xE3y s\u1EED d\u1EE5ng tay
      c\u1EA7m c\u1EE7a m\xECnh:\nXoay c\u1EA7n g\u1EA1t (Joystick): \u0110\u1EC3
      ph\xF3ng to ho\u1EB7c thu nh\u1ECF to\xE0n b\u1ED9 H\u1EC7 M\u1EB7t Tr\u1EDDi.\nCh\u1EC9
      v\xE0 B\u1EA5m (Trigger): H\xE3y ch\u1ECDn v\xE0o m\u1ED9t h\xE0nh tinh b\u1EA5t
      k\u1EF3 \u0111\u1EC3 t\u1EADp trung (Focus) v\xE0o h\xE0nh tinh \u0111\xF3.
      H\u1EC7 th\u1ED1ng s\u1EBD t\u1EF1 \u0111\u1ED9ng \u0111\u01B0a b\u1EA1n \u0111\u1EBFn
      g\u1EA7n n\xF3 h\u01A1n!"
    voiceClip: {fileID: 8300000, guid: 7b9316ab67acef44980b429cea931aa7, type: 3}
    delayAfter: 0
  playOnlyOnce: 0
