--- !u!114 &2120878785
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2120878784}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 53894c554bef8f44696ca48d7efa9f47, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TutorialManager
  guideText: {fileID: 785094210}
  voiceAudioSource: {fileID: 2120878791}
  instructions:
  - "Ch\xE0o m\u1EEBng b\u1EA1n \u0111\u1EBFn v\u1EDBi ph\xF2ng th\xED nghi\u1EC7m
    v\u1EC1 dung d\u1ECBch \u0111\u1EC7m. \u0110\u1EA7u ti\xEAn, h\xE3y l\u1EA5y
    m\u1ED9t chi\u1EBFc c\u1ED1c s\u1EA1ch v\xE0 r\xF3t v\xE0o kho\u1EA3ng 50 ml
    n\u01B0\u1EDBc c\u1EA5t (H2O) t\u1EEB v\xF2i b\u01A1m."
  - "B\xE2y gi\u1EDD, h\xE3y th\xEAm dung d\u1ECBch Axit Clohidric (HCl) v\xE0o c\u1ED1c
    n\u01B0\u1EDBc. B\u1EA1n h\xE3y quan s\xE1t s\u1EF1 thay \u0111\u1ED5i m\xE0u
    s\u1EAFc v\xE0 ch\u1EC9 s\u1ED1 pH tr\xEAn b\u1EA3ng th\xF4ng s\u1ED1."
  - "\u0110\u1ED9 pH gi\u1EA3m v\xE0 m\xE0u chuy\u1EC3n sang \u0111\u1ECF v\xEC Axit
    ph\xE2n ly t\u1EA1o ra ion H+. N\u1ED3ng \u0111\u1ED9 ion H c\u1ED9ng c\xE0ng
    cao th\xEC t\xEDnh axit c\xE0ng m\u1EA1nh, l\xE0m thay \u0111\u1ED5i c\u1EA5u
    tr\xFAc ph\xE2n t\u1EED c\u1EE7a ch\u1EA5t ch\u1EC9 th\u1ECB m\xE0u, m\xE0u s\u1EAFc
    dung d\u1ECBch s\u1EBD chuy\u1EC3n \u0111\u1ECF"
  - "Ti\u1EBFp theo, h\xE3y nh\u1ECF dung d\u1ECBch Natri Hidroxit (NaOH) v\xE0o
    c\u1ED1c \u0111\u1EC3 trung h\xF2a axit. Khi pH ti\u1EBFn d\u1EA7n v\u1EC1 m\u1EE9c
    7, dung d\u1ECBch s\u1EBD chuy\u1EC3n sang m\xE0u xanh l\xE1 c\xE2y, \u0111\xE1nh
    d\u1EA5u tr\u1EA1ng th\xE1i trung t\xEDnh."
  - "N\u1EBFu ti\u1EBFp t\u1EE5c th\xEAm NaOH, n\u1ED3ng \u0111\u1ED9 ion OH- s\u1EBD
    chi\u1EBFm \u01B0u th\u1EBF. Dung d\u1ECBch tr\u1EDF n\xEAn ki\u1EC1m h\xF3a,
    pH t\u0103ng v\u1ECDt l\xEAn tr\xEAn 10 v\xE0 chuy\u1EC3n sang m\xE0u xanh lam
    t\xEDm."
  - "B\xE2y gi\u1EDD, h\xE3y l\u1EA5y chi\u1EBFc c\u1ED1c th\u1EE9 hai v\xE0 r\xF3t
    dung d\u1ECBch \u0110\u1EC7m Amoni v\xE0o. L\u1EA7n l\u01B0\u1EE3t th\xEAm axit
    v\xE0 baz\u01A1 t\u01B0\u01A1ng t\u1EF1 nh\u01B0 th\xED nghi\u1EC7m tr\u01B0\u1EDBc"
  - "B\u1EA1n c\xF3 th\u1EC3 th\u1EA5y pH thay \u0111\u1ED5i r\u1EA5t \xEDt. \u0110\xF3
    l\xE0 nh\u1EDD h\u1EC7 \u0111\u1EC7m ch\u1EE9a c\u1EA3 th\xE0nh ph\u1EA7n axit
    v\xE0 baz\u01A1 y\u1EBFu, ch\xFAng t\u1EF1 \u0111\u1ED9ng ph\u1EA3n \u1EE9ng
    \u0111\u1EC3 ti\xEAu th\u1EE5 c\xE1c ion H+ ho\u1EB7c OH- tr\u1EEB th\xEAm v\xE0o,
    gi\xFAp duy tr\xEC m\xF4i tr\u01B0\u1EDDng \u1ED5n \u0111\u1ECBnh."
  - "H\xE3y t\u1EF1 do ki\u1EC3m nghi\u1EC7m c\xE1c t\u01B0\u01A1ng t\xE1c pH gi\u1EEFa
    c\xE1c dung d\u1ECBch."
  voiceClips:
  - {fileID: 8300000, guid: c40fdd49e57a8f1439998e1587d3f010, type: 3}
