  m_Script: {fileID: 11500000, guid: ece8333fbe2c91249ba92194f6206508, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::SmarthomeTutorialManager
  stages:
  - stageName: Intro
    dialogues:
    - "Ch\xE0o m\u1EEBng b\u1EA1n \u0111\u1EBFn v\u1EDBi th\u1EED nghi\xEAm Nh\xE0
      th\xF4ng minh. H\xF4m nay ch\xFAng ta s\u1EBD c\xF9ng t\xECm hi\u1EC3u v\xE0
      m\xF4 ph\u1ECFng l\u1EA1i c\xE1ch m\u1ED9t ng\xF4i nh\xE0 th\xF4ng minh ho\u1EA1t
      \u0111\u1ED9ng nh\xE9!"
    waitForAction: 0
  - stageName: Task_Spawn
    dialogues:
    - "Tr\u01B0\u1EDBc h\u1EBFt ch\xFAng ta h\xE3y c\xF9ng th\xEAm m\u1ED9t v\xE0i
      thi\u1EBFt b\u1ECB th\xF4ng minh c\xF3 th\u1EC3 \u0111i\u1EC1u khi\u1EC3n t\u1EEB
      xa v\xE0o trong c\u0103n nh\xE0 n\xE0o."
    - "B\u1EA1n h\xE3y s\u1EED d\u1EE5ng b\u1EA3ng \u0111i\u1EC1u khi\u1EC3n tr\xEAn
      c\xE1nh tay tr\xE1i (\u1EA5n B \u0111\u1EC3 b\u1EADt/t\u1EAFt b\u1EA3ng \u0111i\u1EC1u
      khi\u1EC3n), b\u1EA5m v\xE0o n\xFAt \"Thi\u1EBFt b\u1ECB\"."
    - "B\u1EA1n h\xE3y \u1EA5n v\xE0o n\xFAt l\u1EA5y thi\u1EBFt b\u1ECB b\u1EA5t
      k\xEC \u0111\u1EC3 l\u1EA5y thi\u1EBFt b\u1ECB \u0111\xF3 ra nh\xE9."
    - "Khi c\u1EA7m thi\u1EBFt b\u1ECB \u0111\xF3 l\xEAn, b\u1EA1n c\xF3 \u0111\u1EC3
      \xFD th\u1EA5y nh\u1EEFng \u1ED5 \u0111i\u1EC7n m\xE0u xanh l\xE1 xung quanh
      c\u0103n nh\xE0 kh\xF4ng. H\xE3y \u0111\u01B0a thi\u1EBFt b\u1ECB \u0111\xF3
      l\u1EA1i g\u1EA7n v\xE0 th\u1EA3 ra v\xE0o \u1ED5 \u0111i\u1EC7n \u0111\xF3
      nh\xE9! "
    - "Khi g\u1EAFn th\xE0nh c\xF4ng th\xEC thi\u1EBFt b\u1ECB s\u1EBD v\xE0o \u0111\xFAng
      v\u1ECB tr\xED \u0111\xF3. Ch\xFAng ta c\xF9ng ti\u1EBFp t\u1EE5c \u0111\u1EC3
      th\u1EED \u0111i\u1EC1u khi\u1EC3n n\xF3 n\xE0o!"
    waitForAction: 0
  - stageName: Task_Control
    dialogues:
    - "H\xE3y b\u1EADt b\u1ED9 \u0111i\u1EC1u khi\u1EC3n tr\xEAn tay tr\xE1i l\xEAn
      (n\xFAt B). \u1EA4n v\xE0o n\xFAt \"\u0110i\u1EC1u khi\u1EC3n\" \u1EDF g\xF3c
      tr\xEAn b\xEAn tr\xE1i."
    - "B\u1EA1n \u0111\xE3 th\u1EA5y m\u1ED9t danh s\xE1ch c\xE1c thi\u1EBFt b\u1ECB
      ch\u01B0a. C\xE1c thi\u1EBFt b\u1ECB \u0111\xE3 \u0111\u01B0\u1EE3c nh\xF3m
      s\u1EB5n th\xE0nh c\xE1c nh\xF3m kh\xE1c nhau. B\u1EA1n c\xF3 th\u1EC3 k\xE9o
      danh s\xE1ch thi\u1EBFt b\u1ECB \u0111\u1EC3 xem thi\u1EBFt b\u1ECB n\xE0o
      t\u01B0\u01A1ng t\xE1c \u0111\u01B0\u1EE3c."
    - "H\xE3y th\u1EED \u1EA5n n\xFAt b\u1EADt/t\u1EAFt \u0111\u1EC3 b\u1EADt t\u1EAFt
      thi\u1EBFt b\u1ECB b\u1EA1n v\u1EEBa g\u1EAFn l\xEAn xem th\u1EED nh\xE9!"
    - "C\xE1c thi\u1EBFt b\u1ECB th\xF4ng minh hi\u1EC7n nay th\u01B0\u1EDDng ho\u1EA1t
      \u0111\u1ED9ng d\u1EF1a v\xE0o s\u1EF1 k\u1EBFt h\u1EE3p ch\xEDnh gi\u1EEFa
      c\xE1c th\xE0nh ph\u1EA7n: c\u1EA3m bi\u1EBFn, b\u1ED9 \u0111i\u1EC1u khi\u1EC3n,
      k\u1EBFt n\u1ED1i. "
    - "C\xE1c thi\u1EBFt b\u1ECB th\u01B0\u1EDDng th\u01B0c hi\u1EC7n k\u1EBFt n\u1ED1i
      v\u1EDBi nhau th\xF4ng qua m\u1EA1ng internet (ph\u1ED5 bi\u1EBFn nh\u1EA5t
      l\xE0 Wifi)."
    - "Ng\u01B0\u1EDDi d\xF9ng s\u1EBD d\xF9ng c\xE1c b\u1ED9 \u0111i\u1EC1u khi\u1EC3n
      \u0111\u01B0\u1EE3c x\xE2y d\u1EF1ng \u0111\u1EC3 t\xEDch h\u1EE3p v\u1EDBi
      c\xE1c thi\u1EBFt b\u1ECB \u0111\xF3, cho ph\xE9p \u0111i\u1EC1u khi\u1EC3n
      ch\xFAng t\u1EEB xa."
    - "C\xE1c thi\u1EBFt b\u1ECB n\xE0y c\u0169ng c\xF3 th\u1EC3 ho\u1EA1t \u0111\u1ED9ng
      m\u1ED9t c\xE1ch t\u1EF1 \u0111\u1ED9ng th\xF4ng qua c\xE1c c\u1EA3m bi\u1EBFn.
      C\u1EA3m bi\u1EBFn c\u0169ng ph\u1EA3i \u0111\u01B0\u1EE3c k\u1EBFt n\u1ED1i
      v\u1EDBi h\u1EC7 th\u1ED1ng b\u1EB1ng m\u1EA1ng."
    - "C\u1EA3m bi\u1EBFn s\u1EBD ghi nh\u1EADn s\u1EF1 thay \u0111\u1ED5i t\u1EEB
      m\xF4i tr\u01B0\u1EDDng (c\xF3 th\u1EC3 l\xE0 nhi\u1EC7t \u0111\u1ED9, \u0111\u1ED9
      \u1EA9m, \xE1nh s\xE1ng,...). Khi c\xF3 s\u1EF1 thay \u0111\u1ED5i, c\xE1c
      c\u1EA3m bi\u1EBFn s\u1EBD g\u1EEDi l\u1EC7nh t\u1EDBi b\u1ED9 \u0111i\u1EC1u
      khi\u1EC3n \u0111\u1EC3 ra l\u1EC7nh cho c\xE1c thi\u1EBFt b\u1ECB (v\xED d\u1EE5
      nh\u01B0 l\xE0 c\xE1nh c\u1EEDa trong ng\xF4i nh\xE0 n\xE0y)."
    - "B\u1EA1n \u0111\xE3 hi\u1EC3u qua v\u1EC1 c\xE1ch ho\u1EA1t \u0111\u1ED9ng
      c\u1EE7a m\u1ED9t h\u1EC7 th\u1ED1ng thi\u1EBFt b\u1ECB th\xF4ng minh r\u1ED3i.
      Ch\xFAng ta c\xF9ng ti\u1EBFp t\u1EE5c nh\xE9."
    waitForAction: 0
  - stageName: Task_Camera
    dialogues:
    - "M\u1ED9t ng\xF4i nh\xE0 th\xF4ng minh th\u01B0\u1EDDng c\xF3 th\xEAm h\u1EC7
      th\u1ED1ng camera \u0111\u1EC3 gi\xE1m s\xE1t, \u0111\u1EA3m b\u1EA3o an ninh
      cho ch\u1EE7 nh\xE0. B\u1EA1n h\xE3y \u1EA5n v\xE0o n\xFAt \"Camera\" \u1EDF
      trong b\u1EA3ng \u0111i\u1EC1u khi\u1EC3n \u0111\u1EC3 chuy\u1EC3n sang ph\u1EA7n
      gi\xE1m s\xE1t nh\xE9."
    - "B\u1EA1n c\xF3 th\u1EC3 th\u1EA5y camera \u0111ang gi\xE1m s\xE1t ph\u1EA7n
      n\xE0o c\u1EE7a ng\xF4i nh\xE0, v\xE0 chuy\u1EC3n \u0111\u1ED5i gi\u1EEFa nh\u1EEFng
      camera kh\xE1c nhau. N\u1EBFu ch\xFAng b\u1ECB t\u1EAFt \u0111i, b\u1EA1n c\xF3
      th\u1EC3 th\u1EA5y ch\u1EEF \"No Signal\" ngay tr\xEAn m\xE0n h\xECnh \u0111\u1EC3
      ki\u1EC3m tra. B\u1EA1n c\xF3 th\u1EC3 b\u1EADt ch\xFAng l\xEAn l\u1EA1i \u1EDF
      ph\u1EA7n \"\u0110i\u1EC1u khi\u1EC3n\" nh\xE9. "
    - "Ng\u01B0\u1EDDi d\xF9ng c\xF3 th\u1EC3 quan s\xE1t \u0111\u01B0\u1EE3c nh\u1EEFng
      g\xEC \u0111ang di\u1EC5n ra xung quanh ng\xF4i nh\xE0, d\u1EA3m b\u1EA3o an
      to\xE0n cho ch\xEDnh b\u1EA3n th\xE2n t\u1EEB xa. Th\u1EADt ti\u1EC7n l\u1EE3i
      ph\u1EA3i kh\xF4ng ? "
    waitForAction: 0
  - stageName: Outro
    dialogues:
    - "V\u1EADy l\xE0 ch\xFAng ta \u0111\xE3 c\xF9ng t\xECm hi\u1EC3u xong v\u1EC1
      c\xE1ch ho\u1EA1t \u0111\u1ED9ng c\u1EE7a ng\xF4i nh\xE0 th\xF4ng minh r\u1ED3i.
      H\xE3y t\u1EF1 do kh\xE1m ph\xE1 th\u1EED nh\xE9!"
    waitForAction: 0
  tutorialUI: {fileID: 799751606}
  dialogueText: {fileID: 907264964}
  nextButton: {fileID: 297417731}
