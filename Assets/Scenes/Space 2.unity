    - target: {fileID: 958343388726828559, guid: 009ab514ca0a82b46b3cc113342b229c, type: 3}
      propertyPath: description
      value: "Sao H\u1ECFa l\xE0 h\xE0nh tinh th\u1EE9 t\u01B0 t\xEDnh t\u1EEB M\u1EB7t
        Tr\u1EDDi, th\u01B0\u1EDDng \u0111\u01B0\u1EE3c g\u1ECDi l\xE0 \u201CH\xE0nh
        tinh \u0110\u1ECF\u201D do b\u1EC1 m\u1EB7t ch\u1EE9a nhi\u1EC1u oxit s\u1EAFt.
        Sao H\u1ECFa c\xF3 \u0111\u1ECBa h\xECnh \u0111a d\u1EA1ng v\u1EDBi n\xFAi
        l\u1EEDa kh\u1ED5ng l\u1ED3, thung l\u0169ng s\xE2u v\xE0 c\xE1c c\u1EF1c
        b\u0103ng, c\xF9ng b\u1EA7u kh\xED quy\u1EC3n m\u1ECFng ch\u1EE7 y\u1EBFu
        l\xE0 CO2. \u0110\xE2y l\xE0 m\u1ED9t trong nh\u1EEFng m\u1EE5c ti\xEAu quan
        tr\u1ECDng trong vi\u1EC7c t\xECm ki\u1EBFm d\u1EA5u hi\u1EC7u s\u1EF1 s\u1ED1ng
        ngo\xE0i Tr\xE1i \u0110\u1EA5t v\xE0 nghi\xEAn c\u1EE9u kh\u1EA3 n\u0103ng
        con ng\u01B0\u1EDDi sinh s\u1ED1ng trong t\u01B0\u01A1ng lai."
      objectReference: {fileID: 0}
